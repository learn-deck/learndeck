{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.patchquest.example/course/learning-state.v1.schema.json",
  "title": "PatchQuest local learning state",
  "description": "Ignored, learner-owned state used by a local agent to resume evidence-based learning without treating progress as course truth.",
  "type": "object",
  "required": [
    "schemaVersion",
    "sessions",
    "calibration",
    "current",
    "completedModules",
    "completedActivities",
    "checks",
    "conceptLevels",
    "retrievalAttempts",
    "revisions",
    "reviewQueue",
    "reviewHistory",
    "recoveryHistory",
    "checkpoints",
    "lastSessionId",
    "lastSessionAt"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "sessions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Session" }
    },
    "calibration": { "$ref": "#/$defs/Calibration" },
    "current": { "$ref": "#/$defs/CurrentActivity" },
    "completedModules": {
      "type": "array",
      "items": { "$ref": "#/$defs/CompletedModule" }
    },
    "completedActivities": {
      "type": "array",
      "items": { "$ref": "#/$defs/CompletedActivity" }
    },
    "checks": {
      "type": "array",
      "items": { "$ref": "#/$defs/Check" }
    },
    "conceptLevels": {
      "type": "array",
      "items": { "$ref": "#/$defs/ConceptLevel" }
    },
    "retrievalAttempts": {
      "type": "array",
      "items": { "$ref": "#/$defs/RetrievalAttempt" }
    },
    "revisions": {
      "type": "array",
      "items": { "$ref": "#/$defs/EvaluatedRevision" }
    },
    "reviewQueue": {
      "type": "array",
      "items": { "$ref": "#/$defs/ReviewSchedule" }
    },
    "reviewHistory": {
      "type": "array",
      "items": { "$ref": "#/$defs/ReviewEvent" }
    },
    "recoveryHistory": {
      "type": "array",
      "items": { "$ref": "#/$defs/RecoveryEvent" }
    },
    "checkpoints": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Checkpoint" }
    },
    "lastSessionId": { "$ref": "#/$defs/RecordId" },
    "lastSessionAt": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false,
  "$defs": {
    "ModuleId": { "type": "string", "pattern": "^[0-9]{2}$" },
    "RecordId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "minLength": 3,
      "maxLength": 160
    },
    "NonEmptyText": {
      "type": "string",
      "pattern": "\\S",
      "minLength": 3,
      "maxLength": 8000
    },
    "SubstantiveText": {
      "type": "string",
      "pattern": "\\S",
      "minLength": 12,
      "maxLength": 8000
    },
    "SupportLevel": { "enum": ["worked-example", "faded", "independent"] },
    "Session": {
      "type": "object",
      "required": ["sessionId", "status", "startedAt", "endedAt"],
      "properties": {
        "sessionId": { "$ref": "#/$defs/RecordId" },
        "status": { "enum": ["open", "closed"] },
        "startedAt": { "type": "string", "format": "date-time" },
        "endedAt": {
          "oneOf": [
            { "type": "string", "format": "date-time" },
            { "type": "null" }
          ]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "open" } } },
          "then": { "properties": { "endedAt": { "type": "null" } } },
          "else": {
            "properties": {
              "endedAt": { "type": "string", "format": "date-time" }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "Calibration": {
      "type": "object",
      "required": ["status", "evidence", "retentionGoal", "assessedAt"],
      "properties": {
        "status": { "enum": ["unassessed", "concept-specific"] },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/NonEmptyText" }
        },
        "retentionGoal": { "$ref": "#/$defs/NonEmptyText" },
        "assessedAt": {
          "oneOf": [
            { "type": "string", "format": "date-time" },
            { "type": "null" }
          ]
        }
      },
      "additionalProperties": false
    },
    "PendingAction": {
      "type": "object",
      "required": ["owner", "action"],
      "properties": {
        "owner": { "enum": ["learner", "guide"] },
        "action": { "$ref": "#/$defs/NonEmptyText" }
      },
      "additionalProperties": false
    },
    "RecoveryRecord": {
      "type": "object",
      "required": [
        "recoveryId",
        "sessionId",
        "moduleId",
        "activityId",
        "target",
        "preExerciseReference",
        "preExerciseFingerprint",
        "deliberateMutation",
        "expectedFailingCheckId",
        "expectedFailingCommand",
        "expectedFailureCheckRunId",
        "restorationCheckRunId",
        "restorationAction",
        "restoredFingerprint",
        "status",
        "recordedAt",
        "recoveredAt"
      ],
      "properties": {
        "eventId": { "$ref": "#/$defs/RecordId" },
        "recoveryId": { "$ref": "#/$defs/RecordId" },
        "sessionId": { "$ref": "#/$defs/RecordId" },
        "moduleId": { "$ref": "#/$defs/ModuleId" },
        "activityId": { "$ref": "#/$defs/RecordId" },
        "target": { "$ref": "#/$defs/SubstantiveText" },
        "preExerciseReference": { "$ref": "#/$defs/SubstantiveText" },
        "preExerciseFingerprint": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "deliberateMutation": { "$ref": "#/$defs/SubstantiveText" },
        "expectedFailingCheckId": { "$ref": "#/$defs/RecordId" },
        "expectedFailingCommand": { "$ref": "#/$defs/NonEmptyText" },
        "expectedFailureCheckRunId": {
          "oneOf": [{ "$ref": "#/$defs/RecordId" }, { "type": "null" }]
        },
        "restorationCheckRunId": {
          "oneOf": [{ "$ref": "#/$defs/RecordId" }, { "type": "null" }]
        },
        "restorationAction": { "$ref": "#/$defs/SubstantiveText" },
        "restoredFingerprint": {
          "oneOf": [
            { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
            { "type": "null" }
          ]
        },
        "status": {
          "enum": ["pending", "bytes_restored_recheck_pending", "restored"]
        },
        "recordedAt": { "type": "string", "format": "date-time" },
        "recoveredAt": {
          "oneOf": [
            { "type": "string", "format": "date-time" },
            { "type": "null" }
          ]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "pending" } } },
          "then": {
            "properties": {
              "recoveredAt": { "type": "null" },
              "expectedFailureCheckRunId": { "type": "null" },
              "restorationCheckRunId": { "type": "null" },
              "restoredFingerprint": { "type": "null" }
            }
          },
          "else": {
            "if": {
              "properties": {
                "status": { "const": "bytes_restored_recheck_pending" }
              }
            },
            "then": {
              "properties": {
                "recoveredAt": { "type": "null" },
                "expectedFailureCheckRunId": { "$ref": "#/$defs/RecordId" },
                "restorationCheckRunId": { "type": "null" },
                "restoredFingerprint": {
                  "type": "string",
                  "pattern": "^sha256:[a-f0-9]{64}$"
                }
              }
            },
            "else": {
              "properties": {
                "recoveredAt": {
                  "type": "string",
                  "format": "date-time"
                },
                "expectedFailureCheckRunId": { "$ref": "#/$defs/RecordId" },
                "restorationCheckRunId": { "$ref": "#/$defs/RecordId" },
                "restoredFingerprint": {
                  "type": "string",
                  "pattern": "^sha256:[a-f0-9]{64}$"
                }
              }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "RecoveryEvent": {
      "allOf": [
        { "$ref": "#/$defs/RecoveryRecord" },
        {
          "type": "object",
          "required": ["eventId"],
          "properties": {
            "eventId": { "$ref": "#/$defs/RecordId" }
          }
        }
      ]
    },
    "CurrentActivity": {
      "type": "object",
      "required": [
        "sessionId",
        "moduleId",
        "activityId",
        "status",
        "loopPhase",
        "supportLevel",
        "pendingAction",
        "recovery"
      ],
      "properties": {
        "sessionId": { "$ref": "#/$defs/RecordId" },
        "moduleId": { "$ref": "#/$defs/ModuleId" },
        "activityId": { "$ref": "#/$defs/RecordId" },
        "status": {
          "enum": ["calibration", "learning", "review", "blocked", "complete"]
        },
        "loopPhase": {
          "enum": [
            "acquire",
            "retrieve",
            "inspect",
            "act",
            "explain",
            "self-evaluate",
            "correct",
            "prove",
            "feedback",
            "record",
            "recover"
          ]
        },
        "supportLevel": { "$ref": "#/$defs/SupportLevel" },
        "pendingAction": { "$ref": "#/$defs/PendingAction" },
        "recovery": {
          "oneOf": [{ "$ref": "#/$defs/RecoveryRecord" }, { "type": "null" }]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "loopPhase": { "const": "recover" } } },
          "then": {
            "properties": { "recovery": { "$ref": "#/$defs/RecoveryRecord" } }
          },
          "else": { "properties": { "recovery": { "type": "null" } } }
        }
      ],
      "additionalProperties": false
    },
    "RubricCriterion": {
      "type": "object",
      "required": ["criterionId", "score", "evidence"],
      "properties": {
        "criterionId": { "$ref": "#/$defs/RecordId" },
        "score": { "type": "integer", "minimum": 0, "maximum": 2 },
        "evidence": { "$ref": "#/$defs/NonEmptyText" }
      },
      "additionalProperties": false
    },
    "RubricEvaluation": {
      "type": "object",
      "required": ["passed", "criteria"],
      "properties": {
        "passed": { "const": true },
        "criteria": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/RubricCriterion" }
        }
      },
      "additionalProperties": false
    },
    "RetrievalEvidenceRef": {
      "type": "object",
      "required": ["attemptId", "revisionId"],
      "properties": {
        "attemptId": { "$ref": "#/$defs/RecordId" },
        "revisionId": {
          "oneOf": [{ "$ref": "#/$defs/RecordId" }, { "type": "null" }]
        }
      },
      "additionalProperties": false
    },
    "CompletedModule": {
      "type": "object",
      "required": [
        "completionId",
        "moduleId",
        "sessionId",
        "completedAt",
        "repositoryRevision",
        "gateDigest",
        "rubric",
        "activityRunIds",
        "checkRunIds",
        "retrievalEvidenceRefs",
        "delayedReviewIds",
        "firstPersonTakeaway"
      ],
      "properties": {
        "completionId": { "$ref": "#/$defs/RecordId" },
        "moduleId": { "$ref": "#/$defs/ModuleId" },
        "sessionId": { "$ref": "#/$defs/RecordId" },
        "completedAt": { "type": "string", "format": "date-time" },
        "repositoryRevision": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "gateDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "rubric": { "$ref": "#/$defs/RubricEvaluation" },
        "activityRunIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/RecordId" }
        },
        "checkRunIds": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/RecordId" }
        },
        "retrievalEvidenceRefs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/RetrievalEvidenceRef" }
        },
        "delayedReviewIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/RecordId" }
        },
        "firstPersonTakeaway": {
          "type": "string",
          "pattern": "^I\\s+\\S",
          "minLength": 24,
          "maxLength": 4000
        }
      },
      "additionalProperties": false
    },
    "CompletedActivity": {
      "type": "object",
      "required": [
        "activityRunId",
        "sessionId",
        "moduleId",
        "activityId",
        "completedAt",
        "evidence",
        "checkRunIds"
      ],
      "properties": {
        "activityRunId": { "$ref": "#/$defs/RecordId" },
        "sessionId": { "$ref": "#/$defs/RecordId" },
        "moduleId": { "$ref": "#/$defs/ModuleId" },
        "activityId": { "$ref": "#/$defs/RecordId" },
        "completedAt": { "type": "string", "format": "date-time" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/SubstantiveText" }
        },
        "checkRunIds": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/RecordId" }
        }
      },
      "additionalProperties": false
    },
    "Check": {
      "type": "object",
      "required": [
        "checkRunId",
        "checkId",
        "sessionId",
        "moduleId",
        "activityId",
        "command",
        "repositoryRevision",
        "gateDigest",
        "recordedBy",
        "exitCode",
        "outcome",
        "recordedAt",
        "evidence"
      ],
      "properties": {
        "checkRunId": { "$ref": "#/$defs/RecordId" },
        "checkId": { "$ref": "#/$defs/RecordId" },
        "sessionId": { "$ref": "#/$defs/RecordId" },
        "moduleId": { "$ref": "#/$defs/ModuleId" },
        "activityId": { "$ref": "#/$defs/RecordId" },
        "command": { "$ref": "#/$defs/NonEmptyText" },
        "repositoryRevision": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "gateDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "recordedBy": { "const": "learning:check" },
        "exitCode": { "type": "integer", "minimum": -1, "maximum": 255 },
        "outcome": { "enum": ["passed", "failed", "blocked"] },
        "recordedAt": { "type": "string", "format": "date-time" },
        "evidence": { "$ref": "#/$defs/SubstantiveText" }
      },
      "additionalProperties": false
    },
    "ConceptLevel": {
      "type": "object",
      "required": ["conceptId", "sessionId", "level", "evidence", "updatedAt"],
      "properties": {
        "conceptId": { "$ref": "#/$defs/RecordId" },
        "sessionId": { "$ref": "#/$defs/RecordId" },
        "level": { "$ref": "#/$defs/SupportLevel" },
        "evidence": { "$ref": "#/$defs/SubstantiveText" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "Feedback": {
      "type": "object",
      "required": [
        "target",
        "observedEvidence",
        "exactGap",
        "process",
        "correctiveSupport",
        "nextAction",
        "selfMonitoringQuestion"
      ],
      "properties": {
        "target": { "$ref": "#/$defs/SubstantiveText" },
        "observedEvidence": { "$ref": "#/$defs/SubstantiveText" },
        "exactGap": { "$ref": "#/$defs/SubstantiveText" },
        "process": { "$ref": "#/$defs/SubstantiveText" },
        "correctiveSupport": { "$ref": "#/$defs/SubstantiveText" },
        "nextAction": { "$ref": "#/$defs/SubstantiveText" },
        "selfMonitoringQuestion": { "$ref": "#/$defs/SubstantiveText" }
      },
      "additionalProperties": false
    },
    "SelfEvaluation": {
      "type": "object",
      "required": ["criteria"],
      "properties": {
        "criteria": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/RubricCriterion" }
        }
      },
      "additionalProperties": false
    },
    "EvaluatedRevision": {
      "type": "object",
      "required": [
        "revisionId",
        "attemptId",
        "sessionId",
        "moduleId",
        "activityId",
        "promptId",
        "answer",
        "confidencePercent",
        "predictedOutcome",
        "outcome",
        "calibrationNote",
        "selfEvaluation",
        "feedback",
        "evidence",
        "evaluatedAt",
        "checkRunIds"
      ],
      "properties": {
        "revisionId": { "$ref": "#/$defs/RecordId" },
        "attemptId": { "$ref": "#/$defs/RecordId" },
        "sessionId": { "$ref": "#/$defs/RecordId" },
        "moduleId": { "$ref": "#/$defs/ModuleId" },
        "activityId": { "$ref": "#/$defs/RecordId" },
        "promptId": { "$ref": "#/$defs/RecordId" },
        "answer": {
          "type": "string",
          "pattern": "\\S",
          "minLength": 20,
          "maxLength": 8000
        },
        "confidencePercent": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "predictedOutcome": { "enum": ["accurate", "partial", "incorrect"] },
        "outcome": { "enum": ["accurate", "partial", "incorrect"] },
        "calibrationNote": { "$ref": "#/$defs/SubstantiveText" },
        "selfEvaluation": { "$ref": "#/$defs/SelfEvaluation" },
        "feedback": { "$ref": "#/$defs/Feedback" },
        "evidence": { "$ref": "#/$defs/SubstantiveText" },
        "evaluatedAt": { "type": "string", "format": "date-time" },
        "checkRunIds": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/RecordId" }
        }
      },
      "additionalProperties": false
    },
    "ReviewTiming": {
      "type": "object",
      "oneOf": [
        {
          "type": "object",
          "required": ["notBefore"],
          "not": { "required": ["atNextSession"] }
        },
        {
          "type": "object",
          "required": ["atNextSession"],
          "not": { "required": ["notBefore"] }
        }
      ]
    },
    "ReviewSchedule": {
      "type": "object",
      "required": [
        "reviewId",
        "priorReviewId",
        "scheduledBySessionId",
        "promptId",
        "moduleId",
        "conceptIds",
        "heuristic",
        "reason"
      ],
      "properties": {
        "reviewId": { "$ref": "#/$defs/RecordId" },
        "priorReviewId": {
          "oneOf": [{ "$ref": "#/$defs/RecordId" }, { "type": "null" }]
        },
        "scheduledBySessionId": { "$ref": "#/$defs/RecordId" },
        "promptId": { "$ref": "#/$defs/RecordId" },
        "moduleId": { "$ref": "#/$defs/ModuleId" },
        "conceptIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/RecordId" }
        },
        "notBefore": { "type": "string", "format": "date-time" },
        "atNextSession": { "const": true },
        "heuristic": {
          "enum": [
            "corrected-sooner",
            "successful-later",
            "retention-goal",
            "next-session-unknown"
          ]
        },
        "reason": { "$ref": "#/$defs/SubstantiveText" }
      },
      "allOf": [{ "$ref": "#/$defs/ReviewTiming" }],
      "additionalProperties": false
    },
    "ReviewEvent": {
      "type": "object",
      "required": [
        "eventId",
        "eventType",
        "reviewId",
        "priorReviewId",
        "sessionId",
        "promptId",
        "moduleId",
        "conceptIds",
        "heuristic",
        "reason",
        "recordedAt",
        "retrievalEvidenceRef"
      ],
      "properties": {
        "eventId": { "$ref": "#/$defs/RecordId" },
        "eventType": { "enum": ["scheduled", "completed", "rescheduled"] },
        "reviewId": { "$ref": "#/$defs/RecordId" },
        "priorReviewId": {
          "oneOf": [{ "$ref": "#/$defs/RecordId" }, { "type": "null" }]
        },
        "sessionId": { "$ref": "#/$defs/RecordId" },
        "promptId": { "$ref": "#/$defs/RecordId" },
        "moduleId": { "$ref": "#/$defs/ModuleId" },
        "conceptIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/RecordId" }
        },
        "notBefore": { "type": "string", "format": "date-time" },
        "atNextSession": { "const": true },
        "heuristic": {
          "enum": [
            "corrected-sooner",
            "successful-later",
            "retention-goal",
            "next-session-unknown"
          ]
        },
        "reason": { "$ref": "#/$defs/SubstantiveText" },
        "recordedAt": { "type": "string", "format": "date-time" },
        "retrievalEvidenceRef": {
          "oneOf": [
            { "$ref": "#/$defs/RetrievalEvidenceRef" },
            { "type": "null" }
          ]
        }
      },
      "allOf": [
        { "$ref": "#/$defs/ReviewTiming" },
        {
          "if": { "properties": { "eventType": { "const": "scheduled" } } },
          "then": {
            "properties": { "retrievalEvidenceRef": { "type": "null" } }
          },
          "else": {
            "properties": {
              "retrievalEvidenceRef": { "$ref": "#/$defs/RetrievalEvidenceRef" }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "CheckpointSnapshot": {
      "type": "object",
      "required": [
        "current",
        "calibration",
        "conceptLevels",
        "reviewQueue",
        "completedModuleIds",
        "completedActivityRunIds",
        "checkRunIds",
        "retrievalAttemptIds",
        "revisionIds",
        "recoveryEventIds"
      ],
      "properties": {
        "current": { "$ref": "#/$defs/CurrentActivity" },
        "calibration": { "$ref": "#/$defs/Calibration" },
        "conceptLevels": {
          "type": "array",
          "items": { "$ref": "#/$defs/ConceptLevel" }
        },
        "reviewQueue": {
          "type": "array",
          "items": { "$ref": "#/$defs/ReviewSchedule" }
        },
        "completedModuleIds": {
          "type": "array",
          "items": { "$ref": "#/$defs/ModuleId" }
        },
        "completedActivityRunIds": {
          "type": "array",
          "items": { "$ref": "#/$defs/RecordId" }
        },
        "checkRunIds": {
          "type": "array",
          "items": { "$ref": "#/$defs/RecordId" }
        },
        "retrievalAttemptIds": {
          "type": "array",
          "items": { "$ref": "#/$defs/RecordId" }
        },
        "revisionIds": {
          "type": "array",
          "items": { "$ref": "#/$defs/RecordId" }
        },
        "recoveryEventIds": {
          "type": "array",
          "items": { "$ref": "#/$defs/RecordId" }
        }
      },
      "additionalProperties": false
    },
    "Checkpoint": {
      "type": "object",
      "required": [
        "checkpointId",
        "sessionId",
        "recordedAt",
        "reason",
        "previousDigest",
        "evidenceDigest",
        "stateDigest",
        "snapshot"
      ],
      "properties": {
        "checkpointId": { "$ref": "#/$defs/RecordId" },
        "sessionId": { "$ref": "#/$defs/RecordId" },
        "recordedAt": { "type": "string", "format": "date-time" },
        "reason": { "$ref": "#/$defs/SubstantiveText" },
        "previousDigest": {
          "oneOf": [
            { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
            { "type": "null" }
          ]
        },
        "evidenceDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "stateDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "snapshot": { "$ref": "#/$defs/CheckpointSnapshot" }
      },
      "additionalProperties": false
    },
    "RetrievalAttempt": {
      "type": "object",
      "required": [
        "attemptId",
        "sessionId",
        "activityId",
        "promptId",
        "moduleId",
        "conceptIds",
        "attemptedAt",
        "answer",
        "confidencePercent",
        "predictedOutcome",
        "outcome",
        "purpose",
        "status",
        "calibrationNote",
        "misconception",
        "correction",
        "selfEvaluation",
        "feedback",
        "supportLevel",
        "checkRunIds"
      ],
      "properties": {
        "attemptId": { "$ref": "#/$defs/RecordId" },
        "sessionId": { "$ref": "#/$defs/RecordId" },
        "activityId": { "$ref": "#/$defs/RecordId" },
        "promptId": { "$ref": "#/$defs/RecordId" },
        "moduleId": { "$ref": "#/$defs/ModuleId" },
        "conceptIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/RecordId" }
        },
        "attemptedAt": { "type": "string", "format": "date-time" },
        "answer": {
          "type": "string",
          "pattern": "\\S",
          "minLength": 20,
          "maxLength": 8000
        },
        "confidencePercent": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "predictedOutcome": { "enum": ["accurate", "partial", "incorrect"] },
        "outcome": { "enum": ["accurate", "partial", "incorrect"] },
        "purpose": { "enum": ["diagnostic", "mastery", "delayed-review"] },
        "status": { "enum": ["awaiting_revision", "evaluated"] },
        "calibrationNote": { "$ref": "#/$defs/SubstantiveText" },
        "misconception": {
          "oneOf": [{ "$ref": "#/$defs/SubstantiveText" }, { "type": "null" }]
        },
        "correction": {
          "oneOf": [{ "$ref": "#/$defs/SubstantiveText" }, { "type": "null" }]
        },
        "selfEvaluation": { "$ref": "#/$defs/SelfEvaluation" },
        "feedback": { "$ref": "#/$defs/Feedback" },
        "supportLevel": { "$ref": "#/$defs/SupportLevel" },
        "checkRunIds": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/RecordId" }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "outcome": { "enum": ["partial", "incorrect"] } },
            "required": ["outcome"]
          },
          "then": {
            "properties": {
              "misconception": { "$ref": "#/$defs/SubstantiveText" },
              "correction": { "$ref": "#/$defs/SubstantiveText" }
            }
          },
          "else": {
            "properties": {
              "misconception": { "type": "null" },
              "correction": { "type": "null" },
              "status": { "const": "evaluated" }
            }
          }
        }
      ],
      "additionalProperties": false
    }
  }
}
