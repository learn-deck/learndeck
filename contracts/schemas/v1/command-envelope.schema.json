{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.patchquest.example/contracts/v1/command-envelope.schema.json",
  "title": "PatchQuest v1 directed-command envelope",
  "description": "Stable metadata for an imperative v1 request with exactly one intended recipient. Delivery is at least once; commandId is the consumer idempotency key.",
  "type": "object",
  "required": [
    "commandId",
    "commandType",
    "schemaVersion",
    "issuedAt",
    "issuer",
    "recipient",
    "subjectId",
    "correlationId",
    "causationId",
    "data"
  ],
  "properties": {
    "commandId": { "$ref": "shared.schema.json#/$defs/Identifier" },
    "commandType": {
      "type": "string",
      "pattern": "^[a-z]+(?:[.-][a-z]+)*\\.v[1-9][0-9]*$"
    },
    "schemaVersion": { "const": 1 },
    "issuedAt": { "type": "string", "format": "date-time" },
    "issuer": { "enum": ["mission-control"] },
    "recipient": { "enum": ["workshop", "verification-and-review"] },
    "subjectId": { "$ref": "shared.schema.json#/$defs/Identifier" },
    "correlationId": { "$ref": "shared.schema.json#/$defs/Identifier" },
    "causationId": { "$ref": "shared.schema.json#/$defs/Identifier" },
    "data": { "type": "object" }
  },
  "additionalProperties": false
}
