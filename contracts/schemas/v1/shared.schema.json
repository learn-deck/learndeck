{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.patchquest.example/contracts/v1/shared.schema.json",
  "title": "PatchQuest v1 shared contract models",
  "$defs": {
    "Identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "Revision": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "Digest": {
      "type": "object",
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": { "const": "sha256" },
        "value": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    },
    "MissionReference": {
      "type": "object",
      "required": ["missionId", "missionRevision"],
      "properties": {
        "missionId": { "$ref": "#/$defs/Identifier" },
        "missionRevision": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "AllowedScope": {
      "type": "object",
      "required": ["pathPatterns"],
      "properties": {
        "pathPatterns": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 512 }
        }
      },
      "additionalProperties": false
    },
    "AcceptanceGate": {
      "type": "object",
      "required": [
        "gateId",
        "kind",
        "commandId",
        "mandatory",
        "timeoutSeconds",
        "evidenceLimitBytes"
      ],
      "properties": {
        "gateId": { "$ref": "#/$defs/Identifier" },
        "kind": { "enum": ["ALLOWED_SCOPE", "LINT", "TYPECHECK", "TEST"] },
        "commandId": { "$ref": "#/$defs/GateCommandId" },
        "mandatory": { "type": "boolean" },
        "timeoutSeconds": { "type": "integer", "minimum": 1, "maximum": 3600 },
        "evidenceLimitBytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1048576
        }
      },
      "additionalProperties": false
    },
    "GateCommandId": {
      "description": "Portable identifier resolved through the normative v1 gate-command registry; it is never a shell command.",
      "enum": [
        "check-allowed-scope",
        "check-lint",
        "check-typecheck",
        "check-tests"
      ]
    },
    "Artifact": {
      "type": "object",
      "required": ["reference", "digest", "changedPaths"],
      "properties": {
        "reference": { "type": "string", "format": "uri", "maxLength": 2048 },
        "digest": { "$ref": "#/$defs/Digest" },
        "changedPaths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 512 }
        }
      },
      "additionalProperties": false
    },
    "VerificationBinding": {
      "type": "object",
      "required": [
        "missionId",
        "missionRevision",
        "startingRevision",
        "artifactDigest",
        "gateSetDigest"
      ],
      "properties": {
        "missionId": { "$ref": "#/$defs/Identifier" },
        "missionRevision": { "type": "integer", "minimum": 1 },
        "startingRevision": { "$ref": "#/$defs/Revision" },
        "artifactDigest": { "$ref": "#/$defs/Digest" },
        "gateSetDigest": { "$ref": "#/$defs/Digest" }
      },
      "additionalProperties": false
    }
  }
}
