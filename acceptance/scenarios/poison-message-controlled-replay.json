{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schemaVersion": 2,
  "id": "poison-message-controlled-replay",
  "title": "Poison message is dead-lettered and replayed only by operator control",
  "purpose": "Prove invalid delivery is observable, has no business effect, and corrected replay is auditable.",
  "contractVersion": 1,
  "fixtureControls": {
    "authoritativeTimes": {
      "1": "2026-07-12T19:00:00Z",
      "2": "2026-07-12T19:05:00Z",
      "3": "2026-07-12T19:05:00Z"
    },
    "generatedIds": {
      "replayId": "replay-poison-1",
      "verificationRunId": "verification-poison"
    },
    "generatedDigests": {
      "originalPoisonMessage": {
        "algorithm": "sha256",
        "value": "dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd"
      }
    },
    "generatedSecrets": {
      "operatorBearerToken": "fixture-operator-token-000000000000"
    }
  },
  "identities": {
    "correlationId": "corr-poison-001",
    "ids": {
      "missionId": "mission-poison",
      "attemptId": "attempt-poison-1",
      "poisonEventId": "event-poison-original",
      "replayEventId": "event-poison-replay"
    },
    "idempotencyKeys": [
      {
        "key": "event-poison-original",
        "appliesTo": "invalid workshop.artifact-submitted.v1 delivery"
      },
      {
        "key": "event-poison-replay",
        "appliesTo": "controlled corrected replay"
      }
    ]
  },
  "initialState": {
    "authoritativeTime": "2026-07-12T19:00:00Z",
    "mission": {
      "missionId": "mission-poison",
      "missionRevision": 1,
      "status": "ATTEMPT_RUNNING"
    },
    "attempts": [
      {
        "attemptId": "attempt-poison-1",
        "status": "ARTIFACT_SUBMITTED"
      }
    ],
    "verificationRuns": [],
    "completionReviews": [],
    "processedMessageIds": [],
    "deadLetters": [],
    "projections": {
      "mission": {
        "missionId": "mission-poison",
        "status": "ATTEMPT_RUNNING"
      },
      "attempts": [],
      "activity": []
    },
    "missionCompletionProcess": {
      "missionId": "mission-poison",
      "state": "ATTEMPT_ACTIVE"
    }
  },
  "inputs": [
    {
      "sequence": 1,
      "at": "2026-07-12T19:00:00Z",
      "kind": "integrationMessage",
      "messageType": "workshop.artifact-submitted.v1",
      "idempotencyKey": "event-poison-original",
      "expectedContractValidity": "invalid",
      "body": {
        "eventId": "event-poison-original",
        "eventType": "workshop.artifact-submitted.v1",
        "schemaVersion": 1,
        "occurredAt": "2026-07-12T19:00:00Z",
        "producer": "workshop",
        "subjectId": "attempt-poison-1",
        "correlationId": "corr-poison-001",
        "causationId": "http-submit-poison",
        "data": {
          "attemptId": "attempt-poison-1"
        }
      }
    },
    {
      "sequence": 2,
      "at": "2026-07-12T19:05:00Z",
      "kind": "http",
      "operationId": "replayDeadLetter",
      "request": {
        "pathParams": {
          "messageId": "event-poison-original"
        },
        "headers": {
          "X-Request-Id": "00000000-0000-4000-8000-000000000012",
          "X-Correlation-Id": "corr-poison-001",
          "Idempotency-Key": "event-poison-replay",
          "Authorization": "Bearer fixture-operator-token-000000000000"
        },
        "body": {
          "operatorId": "operator-1",
          "reason": "Corrected missing contract fields after inspection",
          "expectedDeadLetterRevision": 1,
          "originalMessageDigest": {
            "algorithm": "sha256",
            "value": "dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd"
          },
          "replacementMessage": {
            "eventId": "event-poison-replay",
            "eventType": "workshop.artifact-submitted.v1",
            "schemaVersion": 1,
            "occurredAt": "2026-07-12T19:05:00Z",
            "producer": "workshop",
            "subjectId": "attempt-poison-1",
            "correlationId": "corr-poison-001",
            "causationId": "event-poison-original",
            "data": {
              "attemptId": "attempt-poison-1",
              "missionId": "mission-poison",
              "missionRevision": 1,
              "startingRevision": "fixture-shipping-v1",
              "runnerId": "runner-fake",
              "artifact": {
                "reference": "urn:patchquest:artifact:poison-replay",
                "digest": {
                  "algorithm": "sha256",
                  "value": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"
                },
                "changedPaths": ["src/shipping/quote.ts"]
              },
              "gateSetDigest": {
                "algorithm": "sha256",
                "value": "bd060aa33a81ad01287b5bb18700a65f7c25707084f142ca044d6f1391a1833b"
              }
            }
          }
        }
      },
      "expect": {
        "status": 202,
        "response": {
          "replayId": "replay-poison-1",
          "originalMessageId": "event-poison-original",
          "replacementMessageId": "event-poison-replay",
          "replacementMessageType": "workshop.artifact-submitted.v1",
          "operatorId": "operator-1",
          "outcome": "REPLAY_ACCEPTED",
          "auditRecordedAt": "2026-07-12T19:05:00Z"
        },
        "captures": {
          "replacementMessageId": "#/body/replacementMessageId"
        }
      }
    },
    {
      "sequence": 3,
      "at": "2026-07-12T19:05:00Z",
      "kind": "await",
      "await": {
        "until": "quiescent",
        "condition": {},
        "timeoutMs": 5000,
        "pollEveryMs": 25
      }
    }
  ],
  "expected": {
    "stepOutcomes": [
      {
        "sequence": 1,
        "result": "dead-lettered",
        "code": "CONTRACT_INVALID",
        "businessEffects": []
      },
      {
        "sequence": 2,
        "result": "replayed",
        "code": "REPLAY_ACCEPTED",
        "businessEffects": [
          "dead letter marked replayed",
          "verification requested once"
        ]
      },
      {
        "sequence": 3,
        "result": "observed",
        "code": "SYSTEM_QUIESCENT",
        "businessEffects": []
      }
    ],
    "finalState": {
      "authoritativeTime": "2026-07-12T19:05:00Z",
      "mission": {
        "missionId": "mission-poison",
        "missionRevision": 1,
        "status": "VERIFICATION_RUNNING"
      },
      "attempts": [
        {
          "attemptId": "attempt-poison-1",
          "status": "ARTIFACT_SUBMITTED"
        }
      ],
      "verificationRuns": [
        {
          "verificationRunId": "verification-poison",
          "status": "REQUESTED"
        }
      ],
      "completionReviews": [],
      "processedMessageIds": ["event-poison-replay"],
      "deadLetters": [
        {
          "originalMessageId": "event-poison-original",
          "messageType": "workshop.artifact-submitted.v1",
          "status": "REPLAYED",
          "replayMessageId": "event-poison-replay",
          "operatorId": "operator-1",
          "revision": 2,
          "originalMessageDigest": {
            "algorithm": "sha256",
            "value": "dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd"
          }
        }
      ],
      "projections": {
        "mission": {
          "missionId": "mission-poison",
          "status": "VERIFICATION_RUNNING"
        },
        "attempts": [],
        "activity": [
          {
            "sequence": 1,
            "kind": "ARTIFACT_SUBMITTED"
          }
        ]
      },
      "missionCompletionProcess": {
        "missionId": "mission-poison",
        "state": "VERIFYING"
      }
    },
    "publishedMessages": [
      {
        "kind": "command",
        "messageType": "verification.start-verification.v1",
        "count": 1,
        "causedBySequence": 2,
        "messageId": "${capture.verification_start_verification_v1_0Id}",
        "correlationId": "corr-poison-001",
        "causationId": "${capture.replacementMessageId}",
        "payloadSubset": {
          "data": {
            "verificationRunId": "verification-poison",
            "attemptId": "attempt-poison-1",
            "producingRunnerId": "runner-fake"
          }
        },
        "captures": {
          "verification_start_verification_v1_0Id": "#/commandId"
        }
      }
    ],
    "notPublishedMessages": [
      {
        "messageType": "verification.start-verification.v1",
        "afterSequence": 1,
        "throughSequence": 1
      }
    ],
    "invariants": [
      "invalid message ID is not marked processed",
      "poison delivery causes no domain or projection effect",
      "replay requires explicit operator identity, reason, and audit linkage",
      "corrected replay receives a distinct idempotency key"
    ]
  },
  "scenarioSchema": "../scenario.schema.json"
}
