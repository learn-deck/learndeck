{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://patchquest.dev/acceptance/scenario.schema.json",
  "title": "PatchQuest implementation-neutral acceptance scenario",
  "type": "object",
  "required": [
    "$schema",
    "scenarioSchema",
    "schemaVersion",
    "id",
    "title",
    "purpose",
    "contractVersion",
    "identities",
    "initialState",
    "inputs",
    "expected"
  ],
  "properties": {
    "$schema": { "const": "https://json-schema.org/draft/2020-12/schema" },
    "scenarioSchema": { "const": "../scenario.schema.json" },
    "schemaVersion": { "const": 2 },
    "id": {
      "$ref": "https://schemas.patchquest.example/contracts/v1/shared.schema.json#/$defs/Identifier"
    },
    "title": { "type": "string", "minLength": 1 },
    "purpose": { "type": "string", "minLength": 1 },
    "contractVersion": { "const": 1 },
    "fixtureControls": { "$ref": "#/$defs/fixtureControls" },
    "identities": { "$ref": "#/$defs/identities" },
    "initialState": { "$ref": "#/$defs/stateSnapshot" },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/input" }
    },
    "expected": { "$ref": "#/$defs/expected" }
  },
  "additionalProperties": false,
  "$defs": {
    "fixtureControls": {
      "type": "object",
      "properties": {
        "authoritativeTimes": {
          "type": "object",
          "description": "Sequence number to the authoritative instant observed while applying that input.",
          "patternProperties": {
            "^[1-9][0-9]*$": { "type": "string", "format": "date-time" }
          },
          "additionalProperties": false
        },
        "generatedIds": {
          "type": "object",
          "description": "Semantic generated-value name to the exact deterministic identifier returned by the fixture port.",
          "additionalProperties": { "$ref": "#/$defs/identifier" }
        },
        "generatedDigests": {
          "type": "object",
          "description": "Semantic evidence or artifact name to the exact deterministic digest returned by the fixture port.",
          "additionalProperties": { "$ref": "#/$defs/digest" }
        },
        "generatedSecrets": {
          "type": "object",
          "description": "Semantic secret name to an opaque deterministic fixture value; never a production secret.",
          "additionalProperties": {
            "type": "string",
            "minLength": 32,
            "maxLength": 512
          }
        },
        "telemetry": { "enum": ["available", "unavailable"] },
        "verifierAssignments": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/identityValue" }
        },
        "gateExecutions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["gateId", "outcome"],
            "properties": {
              "gateId": { "$ref": "#/$defs/identifier" },
              "outcome": {
                "enum": [
                  "PASS",
                  "FAIL",
                  "TIMEOUT",
                  "INFRASTRUCTURE_UNAVAILABLE"
                ]
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "identifier": {
      "$ref": "https://schemas.patchquest.example/contracts/v1/shared.schema.json#/$defs/Identifier"
    },
    "digest": {
      "$ref": "https://schemas.patchquest.example/contracts/v1/shared.schema.json#/$defs/Digest"
    },
    "reference": {
      "type": "string",
      "pattern": "^\\$\\{(?:capture\\.[A-Za-z0-9_-]+|input\\.[1-9][0-9]*\\.(?:requestId|commandId|eventId))\\}$"
    },
    "identityValue": {
      "anyOf": [
        { "$ref": "#/$defs/identifier" },
        { "$ref": "#/$defs/reference" }
      ]
    },
    "digestValue": {
      "oneOf": [{ "$ref": "#/$defs/digest" }, { "$ref": "#/$defs/reference" }]
    },
    "identities": {
      "type": "object",
      "required": ["correlationId", "ids", "idempotencyKeys"],
      "properties": {
        "correlationId": { "$ref": "#/$defs/identityValue" },
        "ids": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/identityValue" }
        },
        "idempotencyKeys": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["key", "appliesTo"],
            "properties": {
              "key": { "$ref": "#/$defs/identifier" },
              "appliesTo": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "httpCommandRequest": {
      "type": "object",
      "required": ["pathParams", "headers", "body"],
      "properties": {
        "pathParams": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/identityValue" }
        },
        "headers": {
          "type": "object",
          "required": ["X-Request-Id", "X-Correlation-Id", "Idempotency-Key"],
          "properties": {
            "X-Request-Id": {
              "oneOf": [
                { "type": "string", "format": "uuid" },
                { "$ref": "#/$defs/reference" }
              ]
            },
            "X-Correlation-Id": { "$ref": "#/$defs/identityValue" },
            "Idempotency-Key": { "$ref": "#/$defs/identityValue" },
            "Authorization": { "type": "string", "pattern": "^Bearer .+" }
          },
          "additionalProperties": { "type": "string" }
        },
        "body": {}
      },
      "additionalProperties": false
    },
    "httpQueryRequest": {
      "type": "object",
      "required": ["pathParams"],
      "properties": {
        "pathParams": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/identityValue" }
        }
      },
      "additionalProperties": false
    },
    "httpExpected": {
      "type": "object",
      "required": ["status", "response"],
      "properties": {
        "status": { "enum": [200, 201, 202, 400, 404, 409, 422] },
        "response": {},
        "captures": {
          "type": "object",
          "description": "Capture name to RFC 6901 JSON Pointer rooted at {status,headers,body}.",
          "additionalProperties": { "type": "string", "pattern": "^#(?:/.*)?$" }
        }
      },
      "additionalProperties": false
    },
    "operationId": {
      "enum": [
        "createMission",
        "getMission",
        "getMissionActivity",
        "getMissionCompletionReview",
        "approveMissionCompletion",
        "rejectMissionCompletion",
        "cancelMission",
        "getAttempt",
        "leaseAttempt",
        "heartbeatAttempt",
        "submitArtifact",
        "replayDeadLetter"
      ]
    },
    "httpCommandOperationId": {
      "enum": [
        "createMission",
        "approveMissionCompletion",
        "rejectMissionCompletion",
        "cancelMission",
        "leaseAttempt",
        "heartbeatAttempt",
        "submitArtifact",
        "replayDeadLetter"
      ]
    },
    "httpQueryOperationId": {
      "enum": [
        "getMission",
        "getMissionActivity",
        "getMissionCompletionReview",
        "getAttempt"
      ]
    },
    "commandMessageType": {
      "enum": [
        "workshop.create-attempt.v1",
        "verification.start-verification.v1",
        "workshop.revoke-attempt.v1"
      ]
    },
    "eventMessageType": {
      "enum": [
        "mission.opened.v1",
        "mission.retry-authorized.v1",
        "mission.cancelled.v1",
        "mission.completed.v1",
        "workshop.attempt-ready.v1",
        "workshop.attempt-leased.v1",
        "workshop.artifact-submitted.v1",
        "workshop.attempt-ended.v1",
        "verification.passed.v1",
        "verification.failed.v1",
        "verification.aborted.v1",
        "review.recommendation-issued.v1"
      ]
    },
    "messageType": {
      "oneOf": [
        { "$ref": "#/$defs/commandMessageType" },
        { "$ref": "#/$defs/eventMessageType" }
      ]
    },
    "inputBase": {
      "type": "object",
      "required": ["sequence", "at", "kind"],
      "properties": {
        "sequence": { "type": "integer", "minimum": 1 },
        "at": { "type": "string", "format": "date-time" },
        "kind": {
          "enum": [
            "http",
            "integrationMessage",
            "advanceTime",
            "controlledReplay",
            "await"
          ]
        },
        "operationId": { "$ref": "#/$defs/operationId" },
        "request": {},
        "expect": { "$ref": "#/$defs/httpExpected" },
        "messageType": { "$ref": "#/$defs/messageType" },
        "body": {},
        "idempotencyKey": { "$ref": "#/$defs/identityValue" },
        "expectedContractValidity": { "enum": ["valid", "invalid"] },
        "await": {
          "type": "object",
          "required": ["until", "timeoutMs", "pollEveryMs", "condition"],
          "properties": {
            "until": { "enum": ["quiescent", "state", "message"] },
            "timeoutMs": { "type": "integer", "minimum": 1 },
            "pollEveryMs": { "type": "integer", "minimum": 1 },
            "condition": { "type": "object" },
            "captures": {
              "type": "object",
              "description": "Capture name to RFC 6901 JSON Pointer rooted at the observed state or message.",
              "additionalProperties": {
                "type": "string",
                "pattern": "^#(?:/.*)?$"
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "input": {
      "oneOf": [
        {
          "allOf": [
            { "$ref": "#/$defs/inputBase" },
            {
              "properties": {
                "kind": { "const": "http" },
                "operationId": { "$ref": "#/$defs/httpCommandOperationId" },
                "request": { "$ref": "#/$defs/httpCommandRequest" }
              },
              "required": ["operationId", "request", "expect"]
            },
            {
              "if": {
                "properties": {
                  "operationId": {
                    "enum": [
                      "approveMissionCompletion",
                      "rejectMissionCompletion",
                      "cancelMission",
                      "leaseAttempt",
                      "heartbeatAttempt",
                      "submitArtifact",
                      "replayDeadLetter"
                    ]
                  }
                },
                "required": ["operationId"]
              },
              "then": {
                "properties": {
                  "request": {
                    "properties": {
                      "headers": { "required": ["Authorization"] }
                    }
                  }
                }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/inputBase" },
            {
              "properties": {
                "kind": { "const": "http" },
                "operationId": { "$ref": "#/$defs/httpQueryOperationId" },
                "request": { "$ref": "#/$defs/httpQueryRequest" }
              },
              "required": ["operationId", "request", "expect"]
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/inputBase" },
            {
              "properties": { "kind": { "const": "integrationMessage" } },
              "required": [
                "messageType",
                "idempotencyKey",
                "expectedContractValidity",
                "body"
              ]
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/inputBase" },
            {
              "properties": { "kind": { "const": "controlledReplay" } },
              "required": ["messageType", "idempotencyKey", "body"]
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/inputBase" },
            {
              "properties": { "kind": { "const": "advanceTime" } },
              "required": ["body"]
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/inputBase" },
            {
              "properties": { "kind": { "const": "await" } },
              "required": ["await"]
            }
          ]
        }
      ]
    },
    "missionStatus": {
      "enum": [
        "OPEN",
        "ATTEMPT_RUNNING",
        "VERIFICATION_RUNNING",
        "COMPLETION_REVIEW",
        "NEEDS_HUMAN_DECISION",
        "COMPLETED",
        "CANCELLED"
      ]
    },
    "mission": {
      "type": ["object", "null"],
      "required": ["missionId", "missionRevision", "status"],
      "properties": {
        "missionId": { "$ref": "#/$defs/identityValue" },
        "missionRevision": { "type": "integer", "minimum": 1 },
        "status": { "$ref": "#/$defs/missionStatus" },
        "gateSetDigest": { "$ref": "#/$defs/digestValue" },
        "latestArtifactDigest": { "$ref": "#/$defs/digestValue" },
        "attemptBudget": { "type": "integer", "minimum": 1 },
        "attemptsAuthorized": { "type": "integer", "minimum": 0 },
        "latestAttemptId": { "$ref": "#/$defs/identityValue" },
        "latestVerificationRunId": { "$ref": "#/$defs/identityValue" },
        "latestVerdict": { "enum": ["PASSED", "FAILED"] },
        "latestRecommendation": { "enum": ["APPROVE", "REQUEST_REVISION"] }
      },
      "additionalProperties": false
    },
    "attempt": {
      "type": "object",
      "required": ["attemptId", "status"],
      "properties": {
        "attemptId": { "$ref": "#/$defs/identityValue" },
        "missionId": { "$ref": "#/$defs/identityValue" },
        "attemptNumber": { "type": "integer", "minimum": 1 },
        "status": {
          "enum": [
            "READY",
            "LEASED",
            "ARTIFACT_SUBMITTED",
            "ABANDONED",
            "FAILED",
            "LEASE_EXPIRED",
            "REVOKED"
          ]
        },
        "runnerId": { "$ref": "#/$defs/identityValue" },
        "leaseToken": { "type": "string", "minLength": 32, "maxLength": 512 },
        "expiresAt": { "type": "string", "format": "date-time" },
        "artifactDigest": { "$ref": "#/$defs/digestValue" },
        "recordedAt": { "type": "string", "format": "date-time" },
        "reason": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "gateCheckResult": {
      "type": "object",
      "required": ["gateId", "outcome"],
      "properties": {
        "gateId": { "$ref": "#/$defs/identifier" },
        "outcome": {
          "enum": ["PASS", "FAIL", "TIMEOUT", "INFRASTRUCTURE_UNAVAILABLE"]
        },
        "evidenceDigest": { "$ref": "#/$defs/digestValue" }
      },
      "additionalProperties": false
    },
    "verificationRun": {
      "type": "object",
      "required": ["verificationRunId", "status"],
      "properties": {
        "verificationRunId": { "$ref": "#/$defs/identityValue" },
        "attemptId": { "$ref": "#/$defs/identityValue" },
        "status": {
          "enum": ["REQUESTED", "RUNNING", "PASSED", "FAILED", "ABORTED"]
        },
        "artifactDigest": { "$ref": "#/$defs/digestValue" },
        "gateSetDigest": { "$ref": "#/$defs/digestValue" },
        "evidenceBundleDigest": { "$ref": "#/$defs/digestValue" },
        "producingRunnerId": { "$ref": "#/$defs/identityValue" },
        "verifierId": { "$ref": "#/$defs/identityValue" },
        "checkCount": { "type": "integer", "minimum": 0 },
        "executionCount": { "type": "integer", "minimum": 1 },
        "failedGateIds": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "checkResults": {
          "type": "array",
          "items": { "$ref": "#/$defs/gateCheckResult" }
        }
      },
      "additionalProperties": false
    },
    "completionReview": {
      "type": "object",
      "required": ["recommendation"],
      "properties": {
        "completionReviewId": { "$ref": "#/$defs/identityValue" },
        "verificationRunId": { "$ref": "#/$defs/identityValue" },
        "artifactDigest": { "$ref": "#/$defs/digestValue" },
        "gateSetDigest": { "$ref": "#/$defs/digestValue" },
        "evidenceBundleDigest": { "$ref": "#/$defs/digestValue" },
        "recommendation": { "enum": ["APPROVE", "REQUEST_REVISION"] },
        "humanDecision": { "enum": ["APPROVED", "REJECTED", null] },
        "reason": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "missionCompletionProcess": {
      "type": ["object", "null"],
      "required": ["missionId", "state"],
      "properties": {
        "missionId": { "$ref": "#/$defs/identityValue" },
        "state": {
          "enum": [
            "IDLE",
            "ATTEMPT_REQUESTED",
            "ATTEMPT_ACTIVE",
            "VERIFICATION_REQUESTED",
            "VERIFYING",
            "AWAITING_HUMAN_REVIEW",
            "RETRY_REQUESTED",
            "COMPLETED",
            "CANCELLED",
            "NEEDS_HUMAN_DECISION"
          ]
        },
        "attemptId": { "$ref": "#/$defs/identityValue" },
        "verificationRunId": { "$ref": "#/$defs/identityValue" },
        "completionReviewId": { "$ref": "#/$defs/identityValue" }
      },
      "additionalProperties": false
    },
    "deadLetter": {
      "type": "object",
      "required": [
        "originalMessageId",
        "messageType",
        "status",
        "originalMessageDigest",
        "revision"
      ],
      "properties": {
        "originalMessageId": { "$ref": "#/$defs/identityValue" },
        "messageType": { "$ref": "#/$defs/messageType" },
        "status": { "enum": ["OPEN", "REPLAYED"] },
        "originalMessageDigest": { "$ref": "#/$defs/digestValue" },
        "replayMessageId": { "$ref": "#/$defs/identityValue" },
        "operatorId": { "$ref": "#/$defs/identityValue" },
        "revision": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "projectionMission": {
      "type": ["object", "null"],
      "properties": {
        "missionId": { "$ref": "#/$defs/identityValue" },
        "status": { "$ref": "#/$defs/missionStatus" },
        "attemptsAuthorized": { "type": "integer", "minimum": 0 },
        "latestVerdict": { "enum": ["PASSED", "FAILED"] },
        "latestRecommendation": { "enum": ["APPROVE", "REQUEST_REVISION"] }
      },
      "additionalProperties": false
    },
    "projectionAttempt": {
      "type": "object",
      "required": ["attemptId", "status"],
      "properties": {
        "attemptId": { "$ref": "#/$defs/identityValue" },
        "status": {
          "enum": [
            "READY",
            "LEASED",
            "ARTIFACT_SUBMITTED",
            "ABANDONED",
            "FAILED",
            "LEASE_EXPIRED",
            "REVOKED"
          ]
        }
      },
      "additionalProperties": false
    },
    "activity": {
      "type": "object",
      "required": ["sequence", "kind"],
      "properties": {
        "sequence": { "type": "integer", "minimum": 1 },
        "kind": {
          "enum": [
            "MISSION_OPENED",
            "ATTEMPT_READY",
            "ATTEMPT_LEASED",
            "ARTIFACT_SUBMITTED",
            "ATTEMPT_ENDED",
            "VERIFICATION_PASSED",
            "VERIFICATION_FAILED",
            "VERIFICATION_ABORTED",
            "RECOMMENDATION_ISSUED",
            "RETRY_AUTHORIZED",
            "MISSION_CANCELLED",
            "MISSION_COMPLETED"
          ]
        }
      },
      "additionalProperties": false
    },
    "projectionSnapshot": {
      "type": "object",
      "required": ["mission", "attempts", "activity"],
      "properties": {
        "mission": { "$ref": "#/$defs/projectionMission" },
        "attempts": {
          "type": "array",
          "items": { "$ref": "#/$defs/projectionAttempt" }
        },
        "activity": { "type": "array", "items": { "$ref": "#/$defs/activity" } }
      },
      "additionalProperties": false
    },
    "stateSnapshot": {
      "type": "object",
      "required": [
        "authoritativeTime",
        "mission",
        "attempts",
        "verificationRuns",
        "completionReviews",
        "missionCompletionProcess",
        "processedMessageIds",
        "deadLetters",
        "projections"
      ],
      "properties": {
        "authoritativeTime": { "type": "string", "format": "date-time" },
        "mission": { "$ref": "#/$defs/mission" },
        "attempts": { "type": "array", "items": { "$ref": "#/$defs/attempt" } },
        "verificationRuns": {
          "type": "array",
          "items": { "$ref": "#/$defs/verificationRun" }
        },
        "completionReviews": {
          "type": "array",
          "items": { "$ref": "#/$defs/completionReview" }
        },
        "missionCompletionProcess": {
          "$ref": "#/$defs/missionCompletionProcess"
        },
        "processedMessageIds": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identityValue" }
        },
        "deadLetters": {
          "type": "array",
          "items": { "$ref": "#/$defs/deadLetter" }
        },
        "projections": { "$ref": "#/$defs/projectionSnapshot" }
      },
      "additionalProperties": false
    },
    "messageExpectationBase": {
      "type": "object",
      "required": [
        "kind",
        "messageType",
        "count",
        "causedBySequence",
        "messageId",
        "correlationId",
        "causationId",
        "payloadSubset"
      ],
      "properties": {
        "kind": { "enum": ["command", "event"] },
        "messageType": { "$ref": "#/$defs/messageType" },
        "count": { "type": "integer", "minimum": 1 },
        "causedBySequence": { "type": "integer", "minimum": 1 },
        "messageId": { "$ref": "#/$defs/identityValue" },
        "correlationId": { "$ref": "#/$defs/identityValue" },
        "causationId": { "$ref": "#/$defs/identityValue" },
        "payloadSubset": { "type": "object" },
        "captures": {
          "type": "object",
          "additionalProperties": { "type": "string", "pattern": "^#(?:/.*)?$" }
        }
      },
      "additionalProperties": false
    },
    "messageExpectation": {
      "oneOf": [
        {
          "allOf": [
            { "$ref": "#/$defs/messageExpectationBase" },
            {
              "properties": {
                "kind": { "const": "command" },
                "messageType": { "$ref": "#/$defs/commandMessageType" },
                "captures": {
                  "type": "object",
                  "additionalProperties": { "const": "#/commandId" }
                }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/messageExpectationBase" },
            {
              "properties": {
                "kind": { "const": "event" },
                "messageType": { "$ref": "#/$defs/eventMessageType" },
                "captures": {
                  "type": "object",
                  "additionalProperties": { "const": "#/eventId" }
                }
              }
            }
          ]
        }
      ]
    },
    "suppression": {
      "type": "object",
      "required": ["messageType", "afterSequence", "throughSequence"],
      "properties": {
        "messageType": { "$ref": "#/$defs/messageType" },
        "afterSequence": { "type": "integer", "minimum": 1 },
        "throughSequence": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "expected": {
      "type": "object",
      "required": [
        "stepOutcomes",
        "finalState",
        "publishedMessages",
        "notPublishedMessages",
        "invariants"
      ],
      "properties": {
        "stepOutcomes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["sequence", "result", "code", "businessEffects"],
            "properties": {
              "sequence": { "type": "integer", "minimum": 1 },
              "result": {
                "enum": [
                  "accepted",
                  "rejected",
                  "idempotent",
                  "dead-lettered",
                  "replayed",
                  "observed"
                ]
              },
              "code": { "$ref": "#/$defs/identifier" },
              "businessEffects": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            },
            "additionalProperties": false
          }
        },
        "finalState": { "$ref": "#/$defs/stateSnapshot" },
        "publishedMessages": {
          "type": "array",
          "items": { "$ref": "#/$defs/messageExpectation" }
        },
        "notPublishedMessages": {
          "type": "array",
          "items": { "$ref": "#/$defs/suppression" }
        },
        "invariants": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
